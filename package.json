{
  "name": "@onenomad/engram-memory",
  "version": "1.0.0-beta.14",
  "description": "Engram — memory MCP server for Claude Code. LLM-powered extraction, hybrid ANN search, tier lifecycle, spreading activation, procedural rules, WAL, Mem0, and session-state.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "engram-memory": "dist/server.js",
    "engram-mcp": "dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "bench": "node --import tsx benchmarks/bench.ts",
    "bench:verbose": "node --import tsx benchmarks/bench.ts --verbose",
    "bench:longmemeval": "node --import tsx benchmarks/longmemeval.ts",
    "bench:locomo": "node --import tsx benchmarks/locomo.ts"
  },
  "dependencies": {
    "openai": "^4.80.0",
    "@huggingface/transformers": "^4.0.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mem0ai": "^2.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
